        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为401\", function () { pm.expect(pm.response.code).to.eql(401); });",
              "pm.test(\"返回错误信息\", function () { var data = pm.response.json(); pm.expect(data.message).to.eql(\"密码错误\"); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
