{
  "info": {
    "name": "电商登录模块接口测试",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. 正常登录",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"test001\",\n  \"password\": \"Test123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "login"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为200\", function () { pm.expect(pm.response.code).to.eql(200); });",
              "pm.test(\"返回了token\", function () { var data = pm.response.json(); pm.expect(data.token).to.not.be.null; });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. 密码错误",
      "request": {
        "method": "POST",
