    {
      "name": "8. SQL注入攻击",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"' OR 1=1 --\",\n  \"password\": \"Test123\"\n}"
